{
  "version": 2,
  "builds": [
    {
      "src": "packages/backend/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "packages/frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/packages/backend/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/packages/frontend/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
