generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}















model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  username      String    @unique
  passwordHash  String
  role          String  @default("VIEWER")
  email         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  managedStores Store[]
  auditLogs     AuditLog[]
  reviews       PerformanceReview[] @relation("Reviewer")
  trainerInductions Induction[] @relation("InductionTrainer")
}

model Store {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String   @unique
  address     String?
  city        String?
  region      String?
  managerId   String?  @db.ObjectId
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager     User?    @relation(fields: [managerId], references: [id], onDelete: SetNull)
  staff       Staff[]
  inventories StoreInventory[]
  requisitions StoreRequisition[]
}

model Staff {
  id                 String       @id @default(auto()) @map("_id") @db.ObjectId
  staffId            String       @unique
  firstName          String
  lastName           String
  email              String?
  phone              String?
  position           String
  department         String?
  storeId            String  @db.ObjectId
  passwordHash       String?
  plainPassword      String?
  status             String  @default("ACTIVE")
  hireDate           DateTime?
  lastPasswordReset  DateTime?
  taxId              String?
  
  gender                  String?
  dob                     DateTime?
  duration                String?
  address                 String?
  stateOfOrigin           String?
  lgaOfOrigin             String?
  nextOfKinName           String?
  nextOfKinPhone          String?
  nextOfKinAddress        String?
  guarantorName           String?
  guarantorPhone          String?
  guarantorAddress        String?
  guarantorEmail          String?
  emergencyContactName    String?
  emergencyContactPhone   String?
  emergencyContactAddress String?

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  store              Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inductions         Induction[]
  performanceReviews PerformanceReview[]
  letters            StaffLetter[]
}



model PerformanceReview {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  staffId     String  @db.ObjectId
  reviewDate  DateTime
  reviewerId  String  @db.ObjectId
  score       Int
  category    String
  comments    String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  staff       Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  reviewer    User   @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([staffId, reviewDate])
}

model AuditLog {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  userId      String  @db.ObjectId
  action      String
  entityType  String
  entityId    String
  oldValue    String?
  newValue    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime        @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model SMTPConfig {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  name              String         @unique
  email             String
  passwordEncrypted String
  server            String
  port              Int
  encryption        String @default("TLS")
  isActive          Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Induction {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  staffId        String    @db.ObjectId
  startDate      DateTime
  completionDate DateTime?
  status         String    @default("PENDING")
  trainerId      String?   @db.ObjectId
  notes          String?
  taxIdVerified  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  staff          Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  trainer        User?     @relation("InductionTrainer", fields: [trainerId], references: [id], onDelete: SetNull)

  @@index([staffId])
}

model StoreInventory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String   @db.ObjectId
  itemName    String
  sku         String?
  quantity    Int      @default(0)
  unit        String   @default("pcs")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  requisitionItems StoreRequisitionItem[]

  @@index([storeId])
}

model StoreRequisition {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId       String   @db.ObjectId
  requesterName String?
  status        String   @default("PENDING") // PENDING, APPROVED, FULFILLED, REJECTED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items         StoreRequisitionItem[]

  @@index([storeId])
}

model StoreRequisitionItem {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  requisitionId     String           @db.ObjectId
  inventoryId       String           @db.ObjectId
  quantityRequested Int
  quantityFulfilled Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  requisition       StoreRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  inventory         StoreInventory   @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
}

model StaffLetter {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  staffId     String   @db.ObjectId
  type        String   // PROMOTION, TERMINATION, WARNING
  subject     String
  content     String
  status      String   @default("DRAFT") // DRAFT, SENT
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}
